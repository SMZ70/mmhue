# Hue Bridge
HUE_BRIDGE_HOST=192.168.1.x
HUE_BRIDGE_APP_KEY=your-app-key-here

# Telegram Interface
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ALLOWED_USER_IDS=[123456789,987654321]

# Optional
LOG_LEVEL=INFO

# Web interface (leave blank and it binds to localhost only)
MMHUE_WEB_PASSWORD=change-me
